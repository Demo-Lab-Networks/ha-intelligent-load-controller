{
  "name": "Intelligent Load Controller",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "containerEnv": {
    "PYTHON_BIN": "python3.13",
    "ILC_DEV_CONFIG_DIR": "/workspaces/ha-intelligent-load-controller/.cache/ha-dev"
  },
  "forwardPorts": [
    8123,
    5173
  ],
  "postCreateCommand": "scripts/bootstrap",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "redhat.vscode-yaml"
      ]
    }
  }
}
